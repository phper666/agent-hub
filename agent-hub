#!/usr/bin/env bash
# ============================================================
#  agent-hub — AI 角色包管理器
#
#  用法：
#    agent-hub init                             初始化项目
#    agent-hub detect                           检测已安装的 Agent
#    agent-hub role list|create|edit|delete     角色管理
#    agent-hub install <role> [--global|--project]  安装角色
#    agent-hub uninstall <role> [--global|--project] 卸载角色
#    agent-hub update <role>                    更新角色
#    agent-hub import <path>                    从其他项目导入角色
#    agent-hub export <role>                    导出角色
#    agent-hub generate <domain>                根据领域生成角色配置
#    agent-hub deps install                     安装依赖
#    agent-hub pipeline status                  查看流水线状态
#    agent-hub help                             显示帮助
# ============================================================

set -e

# 路径（必须在加载其他模块之前定义）
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENT_HUB_DIR="$SCRIPT_DIR"

# 加载公共函数库
source "$SCRIPT_DIR/lib/common.sh"

# 版本（从 VERSION 文件读取）
VERSION="$(get_version "$AGENT_HUB_DIR")"

# 加载模块
source "$SCRIPT_DIR/lib/detect.sh"
source "$SCRIPT_DIR/lib/role.sh"
source "$SCRIPT_DIR/lib/install.sh"
source "$SCRIPT_DIR/lib/pipeline.sh"
source "$SCRIPT_DIR/lib/generate.sh"

# ============================================================
#  help
# ============================================================
cmd_help() {
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║  🦞 agent-hub — AI 角色包管理器 v${VERSION}      ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
  echo ""
  echo "用法: agent-hub <命令> [选项]"
  echo ""
  echo -e "${GREEN}初始化${NC}"
  echo "  init                                    初始化项目目录结构"
  echo ""
  echo -e "${GREEN}平台检测${NC}"
  echo "  detect                                  检测已安装的 Agent 平台"
  echo ""
  echo -e "${GREEN}角色管理${NC}"
  echo "  role list                               列出所有角色"
  echo "  role create <name>                      创建角色模板"
  echo "  role edit <name>                        用编辑器打开角色 SKILL.md"
  echo "  role delete <name>                      删除角色"
  echo "  role info <name>                        查看角色详情"
  echo ""
  echo -e "${GREEN}安装/卸载${NC}"
  echo "  install <role|all> [--global|--project]  安装角色到 Agent 平台"
  echo "  uninstall <role|all> [--global|--project] 卸载角色"
  echo "  update <role|all>                        更新已安装的角色"
  echo "  upgrade                                  升级 agent-hub 自身"
  echo ""
  echo -e "${GREEN}导入/导出${NC}"
  echo "  import <path>                           从其他项目导入角色"
  echo "  export <role> [--output <file>]         导出角色为 YAML"
  echo ""
  echo -e "${GREEN}生成${NC}"
  echo "  generate <domain>                       根据领域生成角色配置"
  echo "                                          可用领域: web, mobile, data, api, ml, devops, game, blockchain, ai, ecommerce"
  echo ""
  echo -e "${GREEN}依赖${NC}"
  echo "  deps install                            安装所有依赖（markitdown 等）"
  echo "  deps list                               列出依赖"
  echo ""
  echo -e "${GREEN}流水线${NC}"
  echo "  pipeline status                         查看项目状态"
  echo "  pipeline reset                          重置状态"
  echo ""
  echo -e "${GREEN}辅助${NC}"
  echo "  version                                 版本信息"
  echo "  help                                    显示帮助"
  echo ""
}

# ============================================================
#  init
# ============================================================
cmd_init() {
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║  🦞 初始化 Agent Hub 项目                ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════╝${NC}"
  echo ""

  # 创建目录结构
  mkdir -p roles .shared/rules .shared/skills templates tests docs/current

  # 创建配置文件
  if [ ! -f "agent-hub.yaml" ]; then
    cat > agent-hub.yaml << 'EOF'
# Agent Hub 项目配置
version: "2.1"

# 角色配置
roles:
  - pm
  - designer
  - frontend
  - backend
  - qa

# 平台配置（detect 自动填充）
platforms: []

# 全局规则
shared_rules:
  - .shared/rules/git-rules.md
  - .shared/rules/quality-rules.md
  - .shared/rules/security-rules.md
EOF
    ok "创建 agent-hub.yaml"
  fi

  # 创建 status.md
  if [ ! -f "docs/current/status.md" ]; then
    cat > docs/current/status.md << 'EOF'
# Project Status

| Role | Status | Updated |
|------|--------|---------|
| PM | ⏳ Pending | - |
| Designer | ⏳ Pending | - |
| Frontend | ⏳ Pending | - |
| Backend | ⏳ Pending | - |
| QA | ⏳ Pending | - |
EOF
    ok "创建 docs/current/status.md"
  fi

  ok "初始化完成"
  echo ""
  info "下一步："
  echo "  1. agent-hub detect          检测已安装的 Agent"
  echo "  2. agent-hub role list       查看角色列表"
  echo "  3. agent-hub install all --global  安装所有角色"
  echo ""
}

# ============================================================
#  version
# ============================================================
cmd_version() {
  echo "agent-hub v${VERSION}"
}

# ============================================================
#  主入口
# ============================================================
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)           cmd_init "$@" ;;
    detect)         cmd_detect "$@" ;;
    role)           cmd_role "$@" ;;
    install)        cmd_install "$@" ;;
    uninstall)      cmd_uninstall "$@" ;;
    update)         cmd_update "$@" ;;
    upgrade)        cmd_upgrade "$@" ;;
    import)         cmd_import "$@" ;;
    export)         cmd_export "$@" ;;
    generate)       cmd_generate "$@" ;;
    deps)           cmd_deps "$@" ;;
    pipeline)       cmd_pipeline "$@" ;;
    version)        cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)              fail "未知命令: $cmd。运行 'agent-hub help' 查看帮助" ;;
  esac
}

main "$@"
